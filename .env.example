# ============================================================
# zowsup-cli Dashboard — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in the real values.
# .env is listed in .gitignore and must NEVER be committed.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   python script/dashboard.py

# ------------------------------------------------------------------
# Dashboard API security
# ------------------------------------------------------------------
# Bearer token required for all API requests except /api/health.
# Generate one:  python -c "import secrets; print(secrets.token_hex(32))"
# Leave empty to disable auth (development only — never in production).
DASHBOARD_API_TOKEN=

# ------------------------------------------------------------------
# Server binding
# ------------------------------------------------------------------
# Address to bind the Flask server to.
# Use 0.0.0.0 to listen on all interfaces (default).
DASHBOARD_HOST=0.0.0.0

# Port to listen on (default: 5000).
DASHBOARD_PORT=5000

# Set to "true" to enable Flask debug mode and auto-reloader.
# MUST be "false" in production — debug mode leaks internal info.
DASHBOARD_DEBUG=false

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------
# Absolute or project-relative path to dashboard.db.
# Default is data/dashboard.db (resolved at runtime relative to project root).
# DASHBOARD_DB_PATH=/custom/path/to/dashboard.db

# ------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL  (default: INFO)
LOG_LEVEL=INFO

# Directory where rotating log files are written.  Created automatically.
# Default: logs/ (relative to project root).
LOG_DIR=logs

# Maximum size of a single log file in bytes (default: 10 MB).
LOG_MAX_BYTES=10485760

# Number of backup log files to keep (default: 5).
LOG_BACKUP_COUNT=5

# ------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------
# Comma-separated list of allowed origins for the /api/* routes.
# Use * during development; set to your actual domain in production.
CORS_ORIGINS=*

# ------------------------------------------------------------------
# Frontend (informational — for the Vite dev server only)
# ------------------------------------------------------------------
# The Vite dev server at http://localhost:5173 proxies /api to this URL.
# Match DASHBOARD_HOST:DASHBOARD_PORT above.
# VITE_API_BASE_URL=http://localhost:5000

# ------------------------------------------------------------------
# Error tracking (Sentry — optional, 8.11)
# ------------------------------------------------------------------
# Set to your Sentry DSN to enable error tracking.
# Requires: pip install sentry-sdk[flask]
# Leave empty to disable.
SENTRY_DSN=

# Environment tag shown in Sentry (e.g. production, staging).
SENTRY_ENVIRONMENT=production

# Fraction of transactions sampled for performance tracing (0.0 – 1.0).
# Set to 0 to disable transaction traces.
SENTRY_TRACES_SAMPLE_RATE=0.1

# Optional: release string (e.g. git commit SHA) for tracking deployments.
# SENTRY_RELEASE=
